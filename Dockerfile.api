# ── FlowOps API ──────────────────────────────────────────────────────────────
FROM node:20-alpine AS api-base
WORKDIR /app/api
COPY flowops-api/package*.json ./
RUN npm ci --omit=dev
COPY flowops-api/ .
RUN npx prisma generate
EXPOSE 4000
CMD ["sh", "-c", "npx prisma migrate deploy && node src/Server.js"]
