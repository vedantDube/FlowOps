# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://flowops:password@localhost:5432/flowops
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret
JWT_SECRET=your-jwt-secret-at-least-16-chars-long

# ── Optional (defaults shown) ────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
LOG_LEVEL=info
JWT_EXPIRY=7d

# ── Encryption (recommended for production) ──────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=your_64_hex_char_key_here

# ── AI Features ──────────────────────────────────────────────────────────────
# GEMINI_API_KEY=your_gemini_api_key

# ── Billing ──────────────────────────────────────────────────────────────────
# RAZORPAY_KEY_ID=your_razorpay_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── Notifications ────────────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# EMAIL_FROM=FlowOps <noreply@flowops.dev>

# ── Integrations ─────────────────────────────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_SIGNING_SECRET=your_slack_signing_secret
