generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth & Users ─────────────────────────────────────────────────────────────

model User {
  id                   String   @id @default(uuid())
  githubId             String   @unique
  username             String
  email                String?
  avatarUrl            String?
  accessToken          String
  onboardingCompleted  Boolean  @default(false)
  preferredMode        String   @default("personal") // "personal" | "org"
  createdAt            DateTime @default(now())

  memberships          OrganizationMember[]
  auditLogs            AuditLog[]
  apiKeys              ApiKey[]
  notificationPref     NotificationPreference?
  profile              DeveloperProfile?
  achievements         UserAchievement[]
  snippets             CodeSnippet[]
  tasks                PersonalTask[]
  orgInvites           OrgInvite[]
  notifications        Notification[]
  reportedIncidents    Incident[]
  dashboardLayouts     DashboardLayout[]
  sentMessages         ChatMessage[] @relation("ChatMessageSender")
  receivedMessages     ChatMessage[] @relation("ChatMessageRecipient")
}

// ─── Organizations & RBAC ─────────────────────────────────────────────────────

model Organization {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  avatarUrl      String?
  // White-label branding (Feature #15)
  customDomain   String?
  customLogo     String?
  primaryColor   String?  @default("#4ADE80")
  companyName    String?
  // Data retention (Feature #14)
  dataRetentionDays Int?  @default(365)
  createdAt      DateTime @default(now())

  members        OrganizationMember[]
  repos          Repository[]
  subscription   Subscription?
  integrations   Integration[]
  auditLogs      AuditLog[]
  documents      Documentation[]
  sprintHealths  SprintHealth[]
  usageRecords   UsageRecord[]
  apiKeys        ApiKey[]
  reviewRules    CustomReviewRule[]
  invites        OrgInvite[]
  automationRules AutomationRule[]
  notifications  Notification[]
  incidents      Incident[]
  dashboardLayouts DashboardLayout[]
  chatMessages   ChatMessage[]
}

model OrganizationMember {
  id             String @id @default(uuid())
  role           String @default("member") // owner | admin | member | viewer

  userId         String
  organizationId String

  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
}

// ─── Chat (1:1 teammate messaging) ────────────────────────────────────────────

model ChatMessage {
  id             String   @id @default(uuid())
  body           String
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  senderId       String
  sender         User @relation("ChatMessageSender", fields: [senderId], references: [id])
  recipientId    String
  recipient      User @relation("ChatMessageRecipient", fields: [recipientId], references: [id])

  @@index([organizationId, createdAt])
  @@index([senderId, recipientId, createdAt])
  @@index([recipientId, senderId, createdAt])
  @@index([recipientId, read])
}

// ─── Repository & Version Control ─────────────────────────────────────────────

model Repository {
  id             String   @id @default(uuid())
  name           String
  fullName       String
  githubRepoId   String   @unique
  defaultBranch  String   @default("main")
  description    String?
  isPrivate      Boolean  @default(false)
  webhookId      Int?     // GitHub webhook ID for cleanup on disconnect
  createdAt      DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  commits        Commit[]
  pullRequests   PullRequest[]
  aiReviews      AICodeReview[]
  documents      Documentation[]
  deployments    Deployment[]
  incidents      Incident[]
}

// ─── DORA Metrics: Deployments ─────────────────────────────────────────────────

model Deployment {
  id             String    @id @default(uuid())
  environment    String    // production | staging | preview | ci
  status         String    // success | failure | pending | in_progress | cancelled
  kind           String    @default("deployment") // "deployment" | "ci_run"
  sha            String
  ref            String?
  workflowRunId  String?   // GitHub deployment id or Actions run id — idempotent upsert key
  workflowName   String?
  deployedAt     DateTime
  createdAt      DateTime  @default(now())

  repositoryId   String
  repository     Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  incidents      Incident[]

  @@unique([repositoryId, workflowRunId])
  @@index([repositoryId, deployedAt])
  @@index([environment, status, deployedAt])
}

// ─── DORA Metrics: Incident Tracking ────────────────────────────────────────────

model Incident {
  id             String    @id @default(uuid())
  title          String
  description    String?
  severity       String    @default("medium") // low | medium | high | critical
  status         String    @default("open")   // open | investigating | resolved
  detectedAt     DateTime  @default(now())
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  repositoryId   String?
  repository     Repository?  @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  deploymentId   String?
  deployment     Deployment?  @relation(fields: [deploymentId], references: [id], onDelete: SetNull)
  reportedById   String?
  reportedBy     User?        @relation(fields: [reportedById], references: [id])

  @@index([organizationId, detectedAt])
  @@index([repositoryId, detectedAt])
  @@index([status])
}

// --- Custom Dashboard Layout ---

model DashboardLayout {
  id             String   @id @default(uuid())
  name           String   @default("My Dashboard") // e.g. "My Sprint View", "Incident Review"
  isDefault      Boolean  @default(false)           // the layout shown by default for this user+org
  widgets        Json     // ordered array of Widget objects, see dashboard-widgets.js
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Nullable userId = an org-wide shared layout (mirrors the Notification
  // userId null-means-org-wide pattern above). A personal layout has userId
  // set; a team layout has it null.
  userId         String?
  user           User?        @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, userId])
}

model Commit {
  id           String   @id @default(uuid())
  sha          String   @unique
  message      String
  author       String
  authorEmail  String?
  additions    Int      @default(0)
  deletions    Int      @default(0)
  filesChanged Int      @default(0)
  committedAt  DateTime

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([repositoryId, committedAt])
  @@index([committedAt])
  @@index([author])
}

model PullRequest {
  id           String    @id @default(uuid())
  number       Int
  title        String
  body         String?
  state        String    // open | closed | merged
  author       String
  headBranch   String?
  baseBranch   String?
  additions    Int       @default(0)
  deletions    Int       @default(0)
  changedFiles Int       @default(0)
  requestedReviewers Json?    // array of GitHub usernames requested for review
  mergeCommitSha String? // GitHub's merge_commit_sha, used to resolve a Deployment.sha back to its PR for DORA lead-time
  openedAt     DateTime
  closedAt     DateTime?
  mergedAt     DateTime?

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  reviews      PullRequestReview[]
  aiReview     AICodeReview?

  @@unique([number, repositoryId])
  @@index([repositoryId, openedAt])
  @@index([closedAt])
  @@index([state])
}

model PullRequestReview {
  id            String   @id @default(uuid())
  state         String   // approved | changes_requested | commented
  reviewer      String
  body          String?
  reviewedAt    DateTime

  pullRequestId String
  pullRequest   PullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)

  @@index([pullRequestId, reviewedAt])
  @@index([reviewedAt])
}

// ─── AI Features ──────────────────────────────────────────────────────────────

model AICodeReview {
  id              String   @id @default(uuid())
  status          String   @default("pending") // pending | completed | failed
  summary         String?
  securityIssues  Json?    // array of { severity, description, line? }
  performanceHints Json?   // array of { description }
  antiPatterns    Json?    // array of { pattern, suggestion }
  refactorSuggestions Json? // array of { description, code? }
  overallScore    Int?     // 0-100
  rawResponse     String?
  createdAt       DateTime @default(now())

  repositoryId    String
  repository      Repository  @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  pullRequestId   String      @unique
  pullRequest     PullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
}

model Documentation {
  id           String   @id @default(uuid())
  type         String   // readme | api | architecture | knowledge-base
  title        String
  content      String   // AI-generated markdown
  status       String   @default("draft") // draft | published | outdated
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  repositoryId   String?
  repository     Repository?   @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
}

// ─── Team Intelligence ─────────────────────────────────────────────────────────

model SprintHealth {
  id                    String   @id @default(uuid())
  sprintName            String
  healthScore           Int      // 0-100
  deliveryPredictability Int     // percentage
  burnoutRisk           String   // low | medium | high
  prCycleAvgHours       Float
  reviewLatencyAvgHours Float
  commitFrequency       Float    // commits per day
  openPRs               Int
  mergedPRs             Int
  insights              Json?    // AI-generated insights array
  generatedAt           DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
}

// ─── Integrations ─────────────────────────────────────────────────────────────

model Integration {
  id             String   @id @default(uuid())
  type           String   // jira | slack | stripe | github
  status         String   @default("active") // active | inactive | error
  config         Json     // encrypted config object
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([type, organizationId])
}

// ─── Billing ──────────────────────────────────────────────────────────────────

model Subscription {
  id                      String    @id @default(uuid())
  razorpaySubscriptionId  String?   @unique
  razorpayPaymentId       String?
  plan                    String    @default("free") // free | pro | enterprise
  status                  String    @default("active") // active | created | cancelled | past_due
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  cancelAtPeriodEnd       Boolean   @default(false)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  organizationId String      @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
}

// ─── Audit Logs ───────────────────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(uuid())
  action         String   // e.g. "repo.connected", "ai.review.generated", "member.invited"
  resourceType   String?
  resourceId     String?
  metadata       Json?
  ipAddress      String?
  createdAt      DateTime @default(now())

  userId         String?
  user           User?         @relation(fields: [userId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([action])
}

// ─── Usage Metering (Feature #2) ──────────────────────────────────────────────

model UsageRecord {
  id             String   @id @default(uuid())
  action         String   // ai_review | doc_generation | api_call
  count          Int      @default(1)
  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, action, periodStart])
}

// ─── API Keys (Feature #12) ──────────────────────────────────────────────────

model ApiKey {
  id             String    @id @default(uuid())
  name           String
  keyHash        String    @unique
  keyPrefix      String    // first 8 chars for display
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  scopes         Json      // array of allowed scopes
  createdAt      DateTime  @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User     @relation(fields: [createdById], references: [id])
}

// ─── Custom AI Review Rules (Feature #7) ──────────────────────────────────────

model CustomReviewRule {
  id             String   @id @default(uuid())
  name           String
  description    String?
  rule           String   // The rule text to inject into AI prompt
  severity       String   @default("warning") // info | warning | error
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
}

// ─── Automation Rules (PR nudges & auto-approve) ──────────────────────────────

model AutomationRule {
  id             String   @id @default(uuid())
  type           String   // stale_pr | unassigned_reviewer | auto_approve
  enabled        Boolean  @default(true)
  thresholdHours Int      @default(48)
  config         Json?    // e.g. { maxChangedFiles, maxDiffLines, docsOnly }
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, type])
}

// ─── Notifications (in-app feed) ───────────────────────────────────────────────

model Notification {
  id             String    @id @default(uuid())
  type           String    // stale_pr | unassigned_reviewer | auto_approved | ai_review | ...
  title          String
  body           String?
  link           String?
  metadata       Json?     // e.g. { prNumber, prAuthor, repoId }
  read           Boolean   @default(false)
  createdAt      DateTime  @default(now())

  // userId set = personal notification; null = org-wide (visible to all members)
  userId         String?
  user           User?         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt])
  @@index([userId, read])
}

// ─── Changelog (Feature #19) ──────────────────────────────────────────────────

model ChangelogEntry {
  id          String   @id @default(uuid())
  version     String?
  title       String
  body        String
  tags        Json?    // array of strings, e.g. ["feature", "ai"]
  published   Boolean  @default(true)
  publishedAt DateTime @default(now())
}

// ─── Notification Preferences (Feature #5) ────────────────────────────────────

model NotificationPreference {
  id             String  @id @default(uuid())
  emailDigest    Boolean @default(true)
  emailBilling   Boolean @default(true)
  emailReview    Boolean @default(false)
  emailWeekly    Boolean @default(true)

  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id])
}

// ─── Individual Developer Features ────────────────────────────────────────────

model DeveloperProfile {
  id          String   @id @default(uuid())
  bio         String?
  website     String?
  twitter     String?
  linkedin    String?
  location    String?
  skills      Json?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
}

model Achievement {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String
  icon        String
  category    String   // commits | reviews | streak | social | docs
  threshold   Int
  createdAt   DateTime @default(now())

  users       UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(uuid())
  progress      Int      @default(0)
  earnedAt      DateTime?
  createdAt     DateTime @default(now())

  userId        String
  user          User        @relation(fields: [userId], references: [id])
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
}

model CodeSnippet {
  id          String   @id @default(uuid())
  title       String
  description String?
  language    String
  code        String
  tags        Json?
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id])
}

model PersonalTask {
  id          String    @id @default(uuid())
  title       String
  description String?
  status      String    @default("todo")
  priority    String    @default("medium")
  repoLink    String?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id])
}

model OrgInvite {
  id             String   @id @default(uuid())
  email          String
  role           String   @default("member")
  status         String   @default("pending")
  token          String   @unique @default(uuid())
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  invitedById    String
  invitedBy      User     @relation(fields: [invitedById], references: [id])
}
